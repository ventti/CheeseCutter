#LIBS=/opt/ldc/build/lib/libphobos-ldc.a /opt/ldc/build/lib/libdruntime-ldc.a -lstdc++
#LIBS=/opt/ldc2/lib/libphobos-ldc.a /opt/ldc2/lib/libdruntime-ldc.a -lstdc++
# libspath from env, default given here
LIBSPATH?=/opt/homebrew/lib
LIBS=${LIBSPATH}/libphobos2-ldc.a ${LIBSPATH}/libdruntime-ldc.a -lstdc++ -L${LIBSPATH} -lsdl2 -lcurl
FRAMEWORKS=-framework Foundation
# Target macOS 15 and later. Exported so every compile (clang for C/C++ AND
# ldc2 for D) stamps the same deployment target as the link; otherwise each
# object defaults to the host SDK version and ld warns "built for newer macOS".
MACDEPLOY?=15.0
export MACOSX_DEPLOYMENT_TARGET=$(MACDEPLOY)
COMFLAGS= -mmacosx-version-min=$(MACDEPLOY)
VERSION=$(shell cat Version)
APPNAME=CheeseCutter-Extended
DLINK=$(COMFLAGS)
DFLAGS=-d-version=DerelictSDL2_Static -I./src -J. -J./src/c64 -J./src/font
CFLAGS=$(COMFLAGS)
CXXFLAGS=$(CFLAGS) -I./src -O2
LDFLAGS=-rpath,@executable_path/../Frameworks
COMPILE.d = $(DC) $(DFLAGS) -d -O2 -c -of=$@ 
DC=ldc2
EXE=
TARGET=ccutter

include Makefile.objects.mk

$(TARGET): $(C64OBJS) $(OBJS) $(CXX_OBJS) $(C_OBJS)
	$(CC) $(DLINK) -Wl,$(LDFLAGS) -o $(TARGET) $(OBJS) $(CXX_OBJS) $(C_OBJS) $(LIBS) $(FRAMEWORKS)

.cpp.o : $(CXX_SRCS)
	$(CXX) $(CXXFLAGS) -c $< -o $@

.c.o : $(C_SRCS)
	$(CC) -c $< -o $@

ct: $(C64OBJS) $(CTOBJS)

ct2util: $(C64OBJS) $(UTILOBJS)
	$(CC) $(DLINK) -o $@ $(UTILOBJS) $(LIBS)

c64: $(C64OBJS)

all: c64 $(OBJS) $(CXX_OBJS) ct2util ct $(TARGET)

# Headless editor driver for agents (see .claude/skills/run-cheesecutter).
# Reuses every editor object except main.o (driver.d is module `main`).
DRIVER = .claude/skills/run-cheesecutter/driver.d
ccdriver: $(C64OBJS) $(filter-out src/main.o,$(OBJS)) $(CXX_OBJS) $(C_OBJS)
	$(DC) $(DFLAGS) -d -O2 -c -of=$(DRIVER:.d=.o) $(DRIVER)
	$(CC) $(DLINK) -Wl,$(LDFLAGS) -o $@ $(filter-out src/main.o,$(OBJS)) $(DRIVER:.d=.o) $(CXX_OBJS) $(C_OBJS) $(LIBS) $(FRAMEWORKS)

# Regenerate the man page and keyboard reference from the tool itself
# (single source of truth: src/main.d cliOptions() and the com.shortcuts registry).
docs: $(TARGET) map
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-man     > doc/ccutter.1
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-man fr  > doc/ccutter.fr.1
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-man de  > doc/ccutter.de.1
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-man sv  > doc/ccutter.sv.1
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-man fi  > doc/ccutter.fi.1
	SDL_VIDEODRIVER=dummy SDL_AUDIODRIVER=dummy ./$(TARGET) --dump-keys    > doc/KEYBOARD.md

# Regenerate the architecture map (doc/ARCHITECTURE.md) from the source itself.
# Pure text parse — no build needed (see tools/genmap.py).
PYTHON?=python3
.PHONY: map check-map
map:
	$(PYTHON) tools/genmap.py

# CI/pre-commit guard: fail if doc/ARCHITECTURE.md is stale vs the source.
check-map:
	$(PYTHON) tools/genmap.py
	git diff --exit-code -- doc/ARCHITECTURE.md

release: all
	strip ccutter$(EXE)
	strip ct2util$(EXE)

	rm -rf $(APPNAME).app
	mkdir -p $(APPNAME).app/Contents/Frameworks
	mkdir -p $(APPNAME).app/Contents/MacOS
	cp -r arch/MacOS/Contents $(APPNAME).app
	# Copy SDL2 dynamic library from Homebrew
	cp -L ${LIBSPATH}/libSDL2*.dylib $(APPNAME).app/Contents/Frameworks/ || true
	cp $(TARGET) $(APPNAME).app/Contents/MacOS
	cp ct2util $(APPNAME).app/Contents/MacOS

dist:	release
	rm -rf dist
	rm -rf $(APPNAME)_$(VERSION).dmg
	arch/makedmg.sh

clean: 
	rm -f *.o *~ resid/*.o resid-fp/*.o ccutter ct2util \
		$(C64OBJS) $(OBJS) $(CTOBJS) $(CXX_OBJS) $(UTILOBJS)

dclean: clean
	rm -rf dist
	rm -rf $(APPNAME).app
	rm -rf $(APPNAME)_$(VERSION).dmg


tar:
	git archive master --prefix=cheesecutter-extended-$(VERSION)/ | bzip2 > cheesecutter-extended-$(VERSION)-macosx-src.tar.bz2
# --------------------------------------------------------------------------------

src/c64/player.bin: src/c64/player_v4.acme
	acme -f cbm --outfile $@ $<

src/ct/base.o: src/c64/player.bin
src/ct/build.o: src/c64/player_v4.acme src/c64/ultimate_host.acme
$(VERSION_USERS): Version
src/ui/ui.o: src/ui/help.o

%.o: %.d
	$(COMPILE.d) $<


